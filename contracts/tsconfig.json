{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "lib", "test", "out", "cache", "cache_hardhat", "artifacts"]
}
