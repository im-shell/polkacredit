# ─── Database ───
DATABASE_FILE=./polkacredit.db

# ─── EVM chain (PolkaCredit contracts via pallet-revive) ───
# Passet Hub is Polkadot's AssetHub testnet on Paseo.
EVM_RPC_URL=https://eth-rpc-testnet.polkadot.io/
EVM_CHAIN_ID=420420417
# Polkadot Hub mainnet:
# EVM_RPC_URL=https://eth-rpc.polkadot.io/
# EVM_CHAIN_ID=420420419
# Local zombienet (polkadot-stack-template):
# EVM_RPC_URL=http://127.0.0.1:8545
# EVM_CHAIN_ID=420420421

# Path to the deployment JSON produced by `forge script script/Deploy.s.sol`.
DEPLOYMENT_FILE=../contracts/deployments/420420417.json

# Indexer signer (must be the same address set as indexer in ScoreRegistry).
INDEXER_PRIVATE_KEY=

# ─── OpenGov (Substrate WSS on the same chain as the contracts) ───
# Contracts and OpenGov both live on AssetHub — same chain, two RPC flavors.
# EVM_RPC_URL above is the pallet-revive JSON-RPC; OPENGOV_WSS below is the
# Substrate WebSocket for the same chain.
ENABLE_OPENGOV=true
# Passet Hub Substrate WSS:
OPENGOV_WSS=wss://asset-hub-paseo-rpc.n.dwellir.com
# Polkadot Hub Substrate WSS:
# OPENGOV_WSS=wss://polkadot-asset-hub-rpc.polkadot.io

# ─── API ───
API_PORT=4000

# ─── Polling / Batching ───
BLOCK_POLL_INTERVAL_MS=12000
SCORE_JOB_INTERVAL_MS=21600000
FINALIZATION_JOB_INTERVAL_MS=900000
