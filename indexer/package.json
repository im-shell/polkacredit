{
  "name": "polkacredit-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Off-chain indexer for PolkaCredit. Watches PolkaCredit contract, Hydration, and OpenGov events; computes points & scores.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --loader tsx src/index.ts",
    "build": "tsc",
    "migrate": "tsx src/db/migrate.ts",
    "api": "tsx src/api/server.ts",
    "verify-score": "tsx src/scripts/verifyScore.ts"
  },
  "dependencies": {
    "@polkadot/api": "^11.0.2",
    "better-sqlite3": "^11.1.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
